# AnkiTUI Configuration Example
# Copy this file to .env and modify as needed

# Logging level: error, warn, info, debug, trace
RUST_LOG=info

# Custom temporary directory (optional, defaults to system temp)
# TMPDIR=./temp

# Data directory (optional, defaults to ~/.local/share/ankitui)
# ANKITUI_DATA_DIR=./data

# UI Configuration (these will be moved to config.toml in future)
# ANKITUI_TITLE=AnkiTUI
# ANKITUI_THEME=default
# ANKITUI_ENABLE_MOUSE=true

# Study Limits (these will be moved to config.toml in future)
# ANKITUI_MAX_NEW_CARDS=20
# ANKITUI_MAX_REVIEW_CARDS=100

# Scheduler Settings (these will be moved to config.toml in future)
# ANKITUI_STARTING_EASE_FACTOR=2.5
# ANKITUI_MAX_INTERVAL=36500