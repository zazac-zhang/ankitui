<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="AnkiTUI"
           Language="1033"
           Version="0.1.0"
           Manufacturer="AnkiTUI Team"
           UpgradeCode="12345678-1234-5678-9012-123456789012">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perMachine"
             Description="AnkiTUI - Terminal Spaced Repetition Learning System"
             Comments="Thank you for installing AnkiTUI!" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of AnkiTUI is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="AnkiTUI" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="ApplicationShortcut" />
      <ComponentRef Id="PathEnvironment" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="AnkiTUI" />
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="AnkiTUI"/>
      </Directory>

      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable">
        <File Id="ankitui.exe"
              Source="$(var.ankitui.TargetPath)"
              KeyPath="yes" />

        <!-- Environment Variable for PATH -->
        <Environment Id="PATH"
                     Name="PATH"
                     Value="[INSTALLFOLDER]"
                     Permanent="no"
                     Part="last"
                     Action="set"
                     System="yes" />
      </Component>
    </ComponentGroup>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="AnkiTUI"
                  Description="Terminal Spaced Repetition Learning System"
                  Target="[#ankitui.exe]"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="ankitui.exe" />
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
        <RegistryValue Root="HKCU"
                       Key="Software\Microsoft\AnkiTUI"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- Uninstall cleanup -->
    <Component Id="PathEnvironment" Directory="INSTALLFOLDER">
      <Condition>REMOVE="ALL"</Condition>
      <Environment Id="PATH"
                   Name="PATH"
                   Value="[INSTALLFOLDER]"
                   Permanent="no"
                   Part="last"
                   Action="remove"
                   System="yes" />
    </Component>

    <!-- Custom actions for data cleanup -->
    <Binary Id="CleanupCa" SourceFile="scripts/cleanup.dll" />
    <CustomAction Id="CleanupUserData"
                  BinaryKey="CleanupCa"
                  DllEntry="CleanupUserData"
                  Execute="deferred"
                  Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="CleanupUserData" After="InstallInitialize">REMOVE="ALL"</Custom>
    </InstallExecuteSequence>

    <Icon Id="ankitui.exe" SourceFile="assets/ankitui.ico" />
  </Product>
</Wix>